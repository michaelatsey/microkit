<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <!-- Package Metadata -->
    <PackageId>MicroKit.Security.ApiKey</PackageId>

    <Description>API key authentication provider for MicroKit.Security — create, validate, rotate, and revoke keys.</Description>
    <Authors>MicroKit Team</Authors>
    <Copyright>Copyright © MicroKit Team 2026</Copyright>
    <PackageTags>security;apikey;microkit;authentication</PackageTags>

    <!-- Documentation -->
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Configuration" Version="10.0.5" />
    <PackageReference Include="Microsoft.Extensions.Options" Version="10.0.5" />
    <PackageReference Include="Microsoft.Extensions.Options.ConfigurationExtensions" Version="10.0.5" />
    <PackageReference Include="Microsoft.Extensions.Options.DataAnnotations" Version="10.0.5" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\MicroKit.Security.Abstractions\MicroKit.Security.Abstractions.csproj" />
    <ProjectReference Include="..\..\MicroKit.Security.Core\MicroKit.Security.Core.csproj" />
  </ItemGroup>

</Project>
