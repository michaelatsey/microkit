<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <!-- Package Metadata -->
    <PackageId>MicroKit.Security.Jwt.AspNetCore</PackageId>
    <Version>1.0.0</Version>
    <Description>ASP.NET Core JWT Bearer extractor for MicroKit.Security — extracts tokens from Authorization headers.</Description>
    <Authors>MicroKit Team</Authors>
    <Copyright>Copyright © MicroKit Team 2026</Copyright>
    <PackageTags>security;jwt;aspnetcore;microkit;bearer</PackageTags>

    <!-- Documentation -->
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\MicroKit.Security.AspNetCore\MicroKit.Security.AspNetCore.csproj" />
    <ProjectReference Include="..\MicroKit.Security.Jwt\MicroKit.Security.Jwt.csproj" />
  </ItemGroup>

</Project>
