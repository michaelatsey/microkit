<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <PackageId>MicroKit.Security.Cognito</PackageId>
    <PackageVersion>1.0.0-preview.1</PackageVersion>
    <Description>AWS Cognito authentication provider for MicroKit.Security. Validates tokens using JWKS discovery.</Description>
    <Authors>Ange Michael Y. ATSE</Authors>
    <Copyright>Copyright © 2024 Ange Michael Y. ATSE</Copyright>
    <PackageTags>microkit;security;aws;cognito;jwt;authentication;dotnet</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="10.0.5" />
    <PackageReference Include="Microsoft.Extensions.Options.ConfigurationExtensions" Version="10.0.5" />
    <PackageReference Include="Microsoft.Extensions.Options.DataAnnotations" Version="10.0.5" />
    <PackageReference Include="Microsoft.IdentityModel.JsonWebTokens" Version="8.16.0" />
    <PackageReference Include="Microsoft.IdentityModel.Protocols.OpenIdConnect" Version="8.16.0" />
    <PackageReference Include="Microsoft.IdentityModel.Tokens" Version="8.16.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\MicroKit.Security.Core\MicroKit.Security.Core.csproj" />
  </ItemGroup>

</Project>
