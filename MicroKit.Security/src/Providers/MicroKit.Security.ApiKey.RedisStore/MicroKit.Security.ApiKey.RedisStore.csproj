<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <!-- Package Metadata -->
    <PackageId>MicroKit.Security.ApiKey.RedisStore</PackageId>

    <Description>Redis-backed API key store for MicroKit.Security — high-performance distributed key storage.</Description>
    <Authors>MicroKit Team</Authors>
    <Copyright>Copyright © MicroKit Team 2026</Copyright>
    <PackageTags>security;apikey;redis;microkit</PackageTags>

    <!-- Documentation -->
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="StackExchange.Redis" Version="2.12.1" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\MicroKit.Security.ApiKey\MicroKit.Security.ApiKey.csproj" />
  </ItemGroup>

</Project>
