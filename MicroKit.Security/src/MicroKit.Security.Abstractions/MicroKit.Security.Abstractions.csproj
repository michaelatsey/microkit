<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <IsAotCompatible>true</IsAotCompatible>
    <IsTrimmable>true</IsTrimmable>
    <EnableTrimAnalyzer>true</EnableTrimAnalyzer>
    <PublishTrimmed>true</PublishTrimmed>

    <!-- Package Metadata -->
    <PackageId>MicroKit.Security.Abstractions</PackageId>
    <Version>1.0.0</Version>
    <Description>Contrats et abstractions pour l'écosystème MicroKit.Security</Description>
    <Authors>MicroKit Team</Authors>
    <Copyright>Copyright © MicroKit Team 2026</Copyright>
    <PackageTags>security;abstractions;microkit;aot;trimming</PackageTags>
    <RepositoryType>git</RepositoryType>

    <!-- Documentation -->
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
  </PropertyGroup>

</Project>
