<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsAotCompatible>true</IsAotCompatible>
    <IsTrimmable>true</IsTrimmable>
    <EnableTrimAnalyzer>true</EnableTrimAnalyzer>

    <!-- Package Metadata -->
    <PackageId>MicroKit.Security.Abstractions</PackageId>
    <Version>1.0.0</Version>
    <Description>Contracts and abstractions for the MicroKit.Security ecosystem. Zero third-party dependencies.</Description>
    <Authors>MicroKit Team</Authors>
    <Copyright>Copyright © MicroKit Team 2026</Copyright>
    <PackageTags>security;abstractions;microkit;aot;trimming;authentication;authorization</PackageTags>
    <RepositoryType>git</RepositoryType>

    <!-- Documentation -->
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

</Project>
