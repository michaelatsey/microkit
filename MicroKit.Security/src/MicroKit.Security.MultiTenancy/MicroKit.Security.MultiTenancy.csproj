<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <PackageId>MicroKit.Security.MultiTenancy</PackageId>
    <PackageVersion>1.0.0-preview.1</PackageVersion>
    <Description>Bridges MicroKit.Security and MicroKit.MultiTenancy: resolves the current tenant from the authenticated security principal.</Description>
    <Authors>Ange Michael Y. ATSE</Authors>
    <Copyright>Copyright © 2024 Ange Michael Y. ATSE</Copyright>
    <PackageTags>microkit;security;multitenant;saas;dotnet</PackageTags>
    <IsAotCompatible>true</IsAotCompatible>
    <IsTrimmable>true</IsTrimmable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="10.0.5" />
    <ProjectReference Include="..\MicroKit.Security.Abstractions\MicroKit.Security.Abstractions.csproj" />
    <ProjectReference Include="..\..\..\MicroKit.MultiTenancy\src\MicroKit.MultiTenancy.Abstractions\MicroKit.MultiTenancy.Abstractions.csproj" />
  </ItemGroup>

</Project>
