{
  "version": "1.0",
  "publicReleaseRefSpec": [
    "^refs/heads/main$",
    "^refs/tags/logging-v\\d+\\.\\d+\\.\\d+(-.+)?$"
  ],
  "pathFilters": [
    "modules/MicroKit.Logging/"
  ],
  "cloudBuild": {
    "setVersionVariables": true
  },
  "release": {
    "tagName": "logging-v{version}",
    "branchName": "release/logging/{version}"
  }
}
