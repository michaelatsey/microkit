    <RootNamespace>MicroKit.Auth.UnitTests</RootNamespace>
    <IsPackable>false</IsPackable>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
    <NoWarn>CS1591;CA1707;CA2012</NoWarn>
