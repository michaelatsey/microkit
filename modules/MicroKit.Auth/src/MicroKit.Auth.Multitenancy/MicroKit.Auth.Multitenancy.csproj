<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <AssemblyName>MicroKit.Auth.Multitenancy</AssemblyName>
    <RootNamespace>MicroKit.Auth.Multitenancy</RootNamespace>
    <Description>Bridge between MicroKit.Auth and MicroKit.Multitenancy — tenant-scoped permission checks via ITenantPermissionChecker.</Description>
    <PackageTags>microkit;auth;multitenancy;tenant;authorization;dotnet</PackageTags>
    <Authors>Ange-Michaël Atsé</Authors>
    <PackageProjectUrl>https://github.com/michaelatsey/microkit</PackageProjectUrl>
    <RepositoryUrl>https://github.com/michaelatsey/microkit</RepositoryUrl>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="../MicroKit.Auth.Abstractions/MicroKit.Auth.Abstractions.csproj" />
  </ItemGroup>
  <!-- DEV: source ProjectReferences — CI/Release: published NuGet packages -->
  <!-- ⚠ Any new cross-module dependency must be added to BOTH ItemGroups -->
  <ItemGroup Condition="'$(CIReleaseBuild)' != 'true'">
    <ProjectReference Include="../../../MicroKit.Multitenancy/src/MicroKit.Multitenancy.Abstractions/MicroKit.Multitenancy.Abstractions.csproj" />
  </ItemGroup>
  <ItemGroup Condition="'$(CIReleaseBuild)' == 'true'">
    <PackageReference Include="MicroKit.Multitenancy.Abstractions" />
  </ItemGroup>
</Project>
