<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <AssemblyName>MicroKit.Auth</AssemblyName>
    <RootNamespace>MicroKit.Auth</RootNamespace>
    <Description>Security context and RBAC engine for MicroKit.Auth — CurrentUser, ICurrentUserAccessor backed by AsyncLocal, permission evaluation, claims mapping.</Description>
    <PackageTags>microkit;auth;authorization;security;rbac;dotnet</PackageTags>
    <Authors>Ange-Michaël Atsé</Authors>
    <PackageProjectUrl>https://github.com/michaelatsey/microkit</PackageProjectUrl>
    <RepositoryUrl>https://github.com/michaelatsey/microkit</RepositoryUrl>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="../MicroKit.Auth.Abstractions/MicroKit.Auth.Abstractions.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
  </ItemGroup>
</Project>
