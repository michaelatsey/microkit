{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "model": "claude-sonnet-4-6",
    "hooks": {
        "PostToolUse": [
            {
                "matcher": "Edit|Write",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash .claude/hooks/scripts/tenancy-architecture-check.sh \"$CLAUDE_TOOL_INPUT_PATH\""
                    },
                    {
                        "type": "command",
                        "command": "bash .claude/hooks/scripts/tenancy-dependency-check.sh \"$CLAUDE_TOOL_INPUT_PATH\""
                    },
                    {
                        "type": "command",
                        "command": "bash .claude/hooks/scripts/tenancy-isolation-check.sh \"$CLAUDE_TOOL_INPUT_PATH\""
                    }
                ]
            }
        ]
    }
}