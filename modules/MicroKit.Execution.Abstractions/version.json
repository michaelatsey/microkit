{
    "version": "1.0.0-preview.1",
    "publicReleaseRefSpec": [
        "^refs/heads/main$",
        "^refs/tags/execution-abstractions-v\\d+\\.\\d+\\.\\d+(-.+)?$"
    ],
    "pathFilters": [
        "modules/MicroKit.Execution.Abstractions/"
    ],
    "cloudBuild": {
        "setVersionVariables": true
    },
    "release": {
        "tagName": "execution-abstractions-v{version}",
        "branchName": "release/execution-abstractions/{version}"
    }
}