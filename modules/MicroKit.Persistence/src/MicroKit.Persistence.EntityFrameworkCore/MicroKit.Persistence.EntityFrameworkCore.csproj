<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <AssemblyName>MicroKit.Persistence.EntityFrameworkCore</AssemblyName>
    <RootNamespace>MicroKit.Persistence.EntityFrameworkCore</RootNamespace>
    <Description>EF Core bridge for MicroKit.Persistence — EfRepository, EfReadRepository, EfUnitOfWork, EfSpecificationEvaluator, ITransactionalUnitOfWork, and the DI registration entry point (PersistenceBuilder).</Description>
    <PackageTags>persistence;ef-core;repository;unit-of-work;microkit;ddd;dotnet</PackageTags>
  </PropertyGroup>
  <!-- DEV: source ProjectReferences — CI/Release: published NuGet packages -->
  <!-- ⚠ Any new cross-module dependency must be added to BOTH ItemGroups -->
  <ItemGroup Condition="'$(CIReleaseBuild)' != 'true'">
    <ProjectReference Include="..\MicroKit.Persistence\MicroKit.Persistence.csproj" />
  </ItemGroup>
  <ItemGroup Condition="'$(CIReleaseBuild)' == 'true'">
    <PackageReference Include="MicroKit.Persistence" />
  </ItemGroup>
  <PropertyGroup>
    <!-- EF Core itself is not fully trim-compatible; suppress the resulting IL2091 warnings
         that propagate when calling DbContext.Set<TEntity>() with a generic type parameter. -->
    <NoWarn>$(NoWarn);IL2091</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.EntityFrameworkCore" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Relational" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
  </ItemGroup>
</Project>
