{
    "version": "1.0.0-preview.2",
    "publicReleaseRefSpec": [
        "^refs/heads/main$",
        "^refs/tags/persistence-v\\d+\\.\\d+\\.\\d+(-.+)?$"
    ],
    "pathFilters": [
        "modules/MicroKit.Persistence/"
    ],
    "cloudBuild": {
        "setVersionVariables": true
    },
    "release": {
        "tagName": "persistence-v{version}",
        "branchName": "release/persistence/{version}"
    }
}