{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "model": "claude-sonnet-4-6",
    "hooks": {
        "PostToolUse": [
            {
                "matcher": "Write|Edit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "dotnet build src/MicroKit.MediatR/MicroKit.MediatR.csproj --nologo --verbosity quiet 2>&1 | tail -3",
                        "timeout": 30
                    }
                ]
            }
        ]
    }
}
