{
  "Microkit": {
    "OpenApi": {
      "Title": "Entitlement Service",
      "Description": "Gère les droits et permissions des utilisateurs.",
      "DefaultVersion": "1.0",
      "SupportedVersions": [ "1.0", "2.0" ],
      "DeprecatedVersions": [ "0.9" ],
      "ApiVersionHeaderKey": "X-Entitlement-Version",
      "EnableScalar": true,
      "EnableVersioning": true,
      "RoutingStyle": "Both",
      "OpenApiRoutePattern": "/openapi/{documentName}.json",
      "ScalarEndpointPath": "/scalar/{documentName}",
      "Contact": {
        "Name": "Entitlement Dev Team",
        "Email": "entitlement@company.com",
        "Url": "https://company.com/teams/entitlement"
      },
      "License": {
        "Name": "MIT",
        "Url": "https://opensource.org/licenses/MIT"
      },
      "TermsOfServiceUrl": "https://company.com/tos",
      "ExternalDocsUrl": "https://docs.company.com/entitlement",
      "ExternalDocsDescription": "External documentation",
      "Securities": [
        {
          "Type": "Bearer",
          "SchemeName": "Token",
          "Description": "Authentification JWT standard."
        },
        {
          "Type": "ApiKey",
          "SchemeName": "ServiceAuth",
          "Name": "X-Internal-Key",
          "Location": "Header",
          "Description": "Accès inter-services (M2M)."
        },
        {
          "Type": "OAuth2",
          "SchemeName": "OAuth2Project",
          "Description": "Flux d'autorisation pour les applications tierces.",
          "FlowType": "AuthorizationCode",
          "AuthorizationUrl": "https://auth.company.com/oauth2/v1/authorize",
          "TokenUrl": "https://auth.company.com/oauth2/v1/token",
          "RefreshUrl": "https://auth.company.com/oauth2/v1/refresh",
          "Scopes": {
            "api:read": "Lire les permissions",
            "api:write": "Modifier les droits",
            "offline_access": "Accès hors-ligne (Refresh Token)"
          }
        }
      ],
      "Servers": [
        {
          "Url": "https://api.company.com",
          "Description": "Production"
        },
        {
          "Url": "https://api-staging.company.com",
          "Description": "Staging"
        }
      ]
    }
  }
}
