{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "model": "claude-sonnet-4-6",
    "permissions": {
        "allow": [
            "Bash(dotnet build *)",
            "Bash(dotnet test *)",
            "Bash(dotnet format *)",
            "Bash(git status *)",
            "Bash(git log *)",
            "Bash(git diff *)"
        ],
        "deny": [
            "Bash(git push * main)",
            "Bash(git push origin main)"
        ]
    },
    "hooks": {
        "SessionStart": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "echo 'MicroKit monorepo session started'"
                    }
                ]
            }
        ],
        "PreToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "if": "Bash(git push * main)",
                        "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"deny\",\"permissionDecisionReason\":\"Push direct sur main interdit — utiliser une PR\"}}'"
                    }
                ]
            }
        ]
    }
}
